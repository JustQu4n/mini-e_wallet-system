{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "e_wallet": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-change-this-in-production-should-be-at-least-32-characters",
    "Issuer": "e-wallet-api",
    "Audience": "e-wallet-app",
    "ExpirationHours": 24
  },
  "Redis": {
    "Connection": "localhost:6379",
    "Enabled": false
  },
  "Hangfire": {
    "Enabled": false
  },
  "AllowedHosts": "*"
}
